---
import {Image} from 'astro:assets';
import ospreyIcon from '../assets/osprey-icon.png';

const links = [
    {href: '/download/', label: 'Download'},
    {href: 'https://github.com/OspreyProject/Osprey/releases', label: 'Changelog'},
];
---

<header class="site-header">
    <div class="wrap header-inner">
        <a class="brand" href="/">
            <Image
                    src={ospreyIcon}
                    alt="Osprey's Icon"
                    title="Osprey"
                    width={32}
                    height={32}
                    densities={[1, 2]}
                    loading="eager"
                    fetchpriority="high"
            />
            <span>Osprey</span>
        </a>

        <nav class="site-nav">
            {links.map((link) => <a href={link.href}>{link.label}</a>)}

            <button type="button" class="theme-toggle" aria-label="Switch between light and dark theme">
                <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="4"/>
                    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/>
                </svg>
                <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24"
                     fill="currentColor" aria-hidden="true">
                    <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/>
                </svg>
            </button>
        </nav>
    </div>
</header>
