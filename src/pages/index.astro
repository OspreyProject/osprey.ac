---
import Base from '../layouts/Base.astro';
import {Image} from 'astro:assets';
import promo1 from '../assets/promo1.png';
import promo2 from '../assets/promo2.png';
import alphamountainLight from '../assets/providers/alphamountain-light.png';
import alphamountainDark from '../assets/providers/alphamountain-dark.png';
import bforeaiLight from '../assets/providers/bforeai-light.png';
import bforeaiDark from '../assets/providers/bforeai-dark.png';
import chainpatrolLight from '../assets/providers/chainpatrol-light.png';
import chainpatrolDark from '../assets/providers/chainpatrol-dark.png';
import izoologicLight from '../assets/providers/izoologic-light.png';
import izoologicDark from '../assets/providers/izoologic-dark.png';

const stores = [
    {
        id: 'chrome',
        label: 'Add to Chrome',
        url: 'https://chromewebstore.google.com/detail/osprey-browser-protection/jmnpibhfpmpfjhhkmpadlbgjnbhpjgnd',
    },
    {
        id: 'firefox',
        label: 'Add to Firefox',
        url: 'https://addons.mozilla.org/en-US/firefox/addon/osprey-browser-protection',
    },
    {
        id: 'edge',
        label: 'Add to Edge',
        url: 'https://microsoftedge.microsoft.com/addons/detail/osprey-browser-protectio/nopglhplnghfhpniofkcopmhbjdonlgn',
    },
];

const shots = [
    {
        img: promo1,
        alt: 'Promotional screenshot captioned "Protect your browser and your privacy", showing the Osprey popup panel.',
        title: 'Protect your browser and your privacy.'
    },
    {
        img: promo2,
        alt: 'Promotional screenshot captioned "Stop malicious websites before they infect you", showing the Osprey warning page.',
        title: 'Stop malicious websites before they infect you.'
    },
];

const features = [
    {
        title: 'Stops fake login pages',
        body: 'Blocks the counterfeit bank and email pages built to capture your password.',
    },
    {
        title: 'Stops viruses and scams',
        body: 'Dangerous downloads, fake stores, and fraud are stopped as soon as you visit them.',
    },
    {
        title: 'Up to 21 checks, not just one',
        body: 'Your browser checks with one threat list. Osprey checks up to 21 different sources at once for every website you visit.',
    },
    {
        title: 'Cannot read your screen',
        body: 'Osprey has no permission to see the pages you look at, so we can\'t see your sensitive information.',
    },
    {
        title: 'No accounts required',
        body: 'You do not have to give your name or email address. Osprey works without any personal information.',
    },
    {
        title: 'Protects your privacy',
        body: 'Osprey does not collect your browsing history. Every link is checked privately and anonymously.',
    },
];

const steps = [
    {
        n: '1',
        title: 'You click a link',
        body: 'Anywhere. An email, a search result, a message from a friend. Osprey checks if it\'s seen that link before. If it hasn\'t...',
    },
    {
        n: '2',
        title: 'Osprey checks the address',
        body: 'Osprey\'s secure proxy server asks up to 22 different sources if the page is safe, and gets an answer in a fraction of a second.',
    },
    {
        n: '3',
        title: 'You get a warning, or nothing at all',
        body: 'If the website is dangerous, Osprey stops it and shows a warning page. If it\'s safe, you see the page as normal.',
    },
];

const rating = 4.9;

const partnerLogos = [
    {light: alphamountainLight, dark: alphamountainDark, name: 'AlphaMountain', width: 227},
    {light: bforeaiLight, dark: bforeaiDark, name: 'BforeAI PreCrime', width: 168},
    {light: chainpatrolLight, dark: chainpatrolDark, name: 'ChainPatrol', width: 192},
    {light: izoologicLight, dark: izoologicDark, name: 'iZOOlogic', width: 206},
];

const comparison = [
    {
        feature: 'Free, no accounts required',
        osprey: 'yes',
        builtin: 'yes',
        malwarebytes: 'yes',
        bitdefender: 'yes'
    },
    {
        feature: 'Checks more than one source',
        osprey: '21 sources',
        builtin: '1 source',
        malwarebytes: '1 source',
        bitdefender: '1 source'
    },
    {
        feature: 'Open-source and auditable',
        osprey: 'yes',
        builtin: 'no',
        malwarebytes: 'no',
        bitdefender: 'no'
    },
    {
        feature: 'Strict no-logging policy',
        osprey: 'yes',
        builtin: 'no',
        malwarebytes: 'no',
        bitdefender: 'no'
    },
    {
        feature: 'Configurable threat sources',
        osprey: 'yes',
        builtin: 'no',
        malwarebytes: 'yes',
        bitdefender: 'no'
    },
    {
        feature: 'Doesn\'t slow down browsing',
        osprey: 'yes',
        builtin: 'yes',
        malwarebytes: 'no',
        bitdefender: 'no'
    },
    {
        feature: 'Shows no adverts or upsells',
        osprey: 'yes',
        builtin: 'yes',
        malwarebytes: 'no',
        bitdefender: 'yes'
    },
    {
        feature: 'Blocks >90% on OpenPhish',
        osprey: 'yes',
        builtin: 'no',
        malwarebytes: 'yes',
        bitdefender: 'no'
    },
    {
        feature: 'Blocks newly registered domains',
        osprey: 'yes',
        builtin: 'no',
        malwarebytes: 'no',
        bitdefender: 'no'
    },
    {
        feature: 'Instant updates to threat sources',
        osprey: 'yes',
        builtin: 'no',
        malwarebytes: 'no',
        bitdefender: 'yes'
    }
];

const faqs = [
    {
        q: 'How do I use Osprey? What do I do after it\'s installed?',
        a: 'Once installed, Osprey will automatically start protecting you. You don\'t need to do anything else. It will check every website you visit against the threat intelligence providers you have enabled, and block any that are dangerous.',
    },
    {
        q: 'What do the settings under \'Protection Providers\' do? Should I touch them?',
        a: 'You can leave them alone. Every provider is enabled by default, and Osprey will check every website you visit against all of them. You can turn any of them off if you want, or add your own API keys for some providers. A protection provider is just a third-party service that provides threat intelligence to Osprey. Threat intelligence refers to information about malicious websites, phishing pages, scams, and other online threats.',
    },
    {
        q: 'Can I turn one of the protection providers off?',
        a: 'Yes, any of them, whenever you like. Click the Osprey icon, choose Open Settings, and switch off the ones you do not want. The default settings are recommended for most users, but you can customize them to your needs. You can also add your own API keys for some providers if you have them.',
    },
    {
        q: 'Do I need Osprey if my browser already has protection?',
        a: 'Yes. Your browser\'s built-in protection is a good start, but it only checks against one source of threat intelligence, which misses a lot of new phishing websites. Osprey checks every website you visit against up to 21 different sources, so it can catch more threats and block them before they load.',
    },
    {
        q: 'Will it slow my computer down?',
        a: 'No. Osprey is built to be as lightweight as possible. It doesn\'t stop pages from loading, and it checks every website in a fraction of a second. You won\'t notice any difference to your browsing speed.',
    },
    {
        q: 'Will it stop websites from working properly?',
        a: 'No. Osprey either lets a website through completely untouched, or it stops it and shows a warning. There is no in-between. It doesn\'t check page contents or modify anything, so it cannot break a website. It only blocks the whole page if it is dangerous.',
    },
    {
        q: 'What if it blocks a website I know is fine?',
        a: 'You can add the website to your list of exclusions, click through the \'Continue anyway\' button, or turn off the protection provider that blocked it. You can also take some time to report it as a false positive.',
    },
    {
        q: 'Does it work in private or incognito windows?',
        a: 'Yes, if you switch it on for those windows. Your browser keeps that turned off by default for every add-on. Private windows stay completely separate from your normal browsing.',
    },
    {
        q: 'The report button opens a blank page. What do I do?',
        a: 'You might not have a default mailto: handler set up on your computer. Osprey uses mailto: links to create pre-written emails to threat intelligence providers. You can either set up a default mailto: handler, or copy the email address and paste it into your email program.',
    },
    {
        q: 'How is my privacy protected when it checks a website?',
        a: 'Osprey sends the URL of the page you are visiting to our private proxy server, which checks it against the threat intelligence providers. Since every provider only sees the proxy server\'s IP address, there\'s no way for them to know who you are or what you are looking at. Osprey does not log your browsing history, and the proxy server does not log your IP address.',
    },
    {
        q: 'Can I replace my ad blocker with Osprey?',
        a: 'No. Osprey does not block ads. It only blocks websites that are dangerous, and it does not modify any page contents. You can keep your ad blocker installed alongside Osprey.',
    },
    {
        q: 'Will it cause issues with my antivirus or my ad blocker?',
        a: 'No. Osprey does a different job from both and is built to sit alongside them. Keep everything you already have. You do not need to turn anything off.',
    },
    {
        q: 'How can I deploy Osprey across an organization?',
        a: 'Osprey installs from the Chrome, Edge, and Firefox stores, so it can be pushed to managed browsers the same way as any other extension through your existing device management. Because it needs no account and no license keys, there is nothing to provision per user, and every provider is enabled by default. The source is public if your security team wants to review it before rolling it out.',
    },
    {
        q: 'Is anyone still working on it?',
        a: 'Yes. Osprey is updated regularly and every change is published publicly the day it is made. You can see the source code and the changelog on GitHub, and you can report bugs or request features there too.',
    }
];

const schema = {
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'SoftwareApplication',
            '@id': 'https://osprey.ac/#software',
            name: 'Osprey: Browser Protection',
            alternateName: 'Osprey',
            applicationCategory: 'SecurityApplication',
            applicationSubCategory: 'Browser Extension',
            operatingSystem: 'Chrome, Firefox, Edge',
            description:
                'Osprey is a free, open-source browser extension that blocks phishing, malware, scams, and other dangerous websites before they load. It checks every site you visit against 21 different threat intelligence providers through a privacy-preserving proxy that hides your IP address.',
            url: 'https://osprey.ac/',
            downloadUrl: 'https://osprey.ac/download/',
            softwareVersion: '2.0.4.3',
            license: 'https://www.gnu.org/licenses/gpl-3.0.html',
            isAccessibleForFree: true,
            offers: {
                '@type': 'Offer',
                price: '0',
                priceCurrency: 'USD',
            },
            featureList: [
                'Blocks phishing and fake login pages',
                'Blocks malware and malicious websites',
                'Blocks scams and online fraud',
                'Checks 21 different threat intelligence providers, not one',
                'Cannot read page content: no host permissions',
                'No account, no ads, no premium tier',
            ],
            permissions: 'tabs, webNavigation, storage',
            privacyPolicy: 'https://osprey.ac/privacy/',
            codeRepository: 'https://github.com/OspreyProject/Osprey',
            author: {'@id': 'https://osprey.ac/#project'},
        },
        {
            '@type': 'FAQPage',
            '@id': 'https://osprey.ac/#faq',
            mainEntity: faqs.map((faq) => ({
                '@type': 'Question',
                name: faq.q,
                acceptedAnswer: {
                    '@type': 'Answer',
                    text: faq.a,
                },
            })),
        },
    ],
};
---

<Base
        schema={schema}
        title="Osprey: Browser Protection"
        description="Free, open-source safe browsing extension that automatically blocks phishing, malware, scams, and dangerous websites."
>
    <section class="hero">
        <h1>Osprey: Browser Protection</h1>
        <p class="hero-sub">
            Free, open-source safe browsing extension that automatically blocks phishing, malware, scams, and dangerous
            websites.
        </p>

        <noscript>
            <style is:inline>
                .install-btn[data-browser="chrome"] {
                    display: inline-flex;
                }
            </style>
        </noscript>

        <div class="install-row">
            {
                stores.map((store) => (
                        <a
                                class="install-btn"
                                data-browser={store.id}
                                href={store.url}
                        >
                            {store.label}
                        </a>
                ))
            }
            <a class="install-btn install-btn-github" href="https://github.com/OspreyProject/Osprey">
                View on GitHub
            </a>
        </div>
    </section>

    <div class="trust-line">
        <p class="trust-rating">
            <span class="stars" role="img" aria-label={`Rated ${rating} out of 5`}>
                {
                    Array.from({length: 5}).map((_, i) => (
                            <span class:list={['star', {filled: i < Math.round(rating)}]}
                                  aria-hidden="true">&#9733;</span>
                    ))
                }
            </span>
            <span><strong>{rating.toFixed(1)}</strong> rating</span>
        </p>
        <p class="trust-users">
            <strong id="user-count">15,000+</strong> users protected
        </p>
    </div>

    <ul class="shots">
        {
            shots.map((shot) => (
                    <li>
                        <button class="shot-trigger" type="button" data-full={shot.img.src}>
                            <Image
                                    src={shot.img}
                                    alt={shot.alt}
                                    title={shot.title}
                                    widths={[450, 740, 900]}
                                    sizes="(max-width: 40rem) calc(100vw - 2.5rem), 450px"
                                    loading="eager"
                                    fetchpriority="high"
                                    decoding="sync"
                            />
                        </button>
                    </li>
            ))
        }
    </ul>

    <section class="partners-strip" aria-label="Threat intelligence partners">
        <p class="partners-label">Partnered with</p>
        <div class="marquee">
            <ul class="marquee-track" data-marquee>
                {
                    partnerLogos.map((logo) => (
                            <li class="marquee-item" data-marquee-set>
                                <Image
                                        class="logo-light"
                                        src={logo.light}
                                        alt={`Logo for ${logo.name}`}
                                        title={logo.name}
                                        width={logo.width}
                                        height={48}
                                        densities={[1, 2]}
                                        loading="lazy"
                                />
                                <Image
                                        class="logo-dark"
                                        src={logo.dark}
                                        alt={`Logo for ${logo.name}`}
                                        title={logo.name}
                                        width={logo.width}
                                        height={48}
                                        densities={[1, 2]}
                                        loading="lazy"
                                />
                            </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <section class="band">
        <h2 class="band-title">What Osprey does</h2>
        <ul class="feature-grid">
            {
                features.map((feature) => (
                        <li class="feature">
                            <h3>{feature.title}</h3>
                            <p>{feature.body}</p>
                        </li>
                ))
            }
        </ul>
    </section>

    <section class="band">
        <h2 class="band-title">How it works</h2>
        <ol class="steps">
            {
                steps.map((step) => (
                        <li class="step">
                            <span class="step-n">{step.n}</span>
                            <h3>{step.title}</h3>
                            <p>{step.body}</p>
                        </li>
                ))
            }
        </ol>
    </section>

    <section class="band">
        <h2 class="band-title">How Osprey started</h2>
        <div class="prose">
            <p>
                &emsp;&emsp;&emsp;Osprey was created in October 2024 to end the need to install multiple safe-browsing
                extensions just to get adequate phishing protection. The protection built into most browsers isn't
                enough on its own anymore, and users shouldn't have to sacrifice their privacy or performance to stay
                safe online. Osprey is built to be extremely lightweight, privacy-preserving, and thorough, checking
                every website you visit against multiple threat intelligence sources, rather than relying on a single
                list.
            </p>
            <p>
                &emsp;&emsp;&emsp;The mission is simple: be the most trusted, transparent, and effective browser
                protection extension for home users and businesses, while staying free and open-source, forever. Osprey
                will never collect, profile, or sell your browsing data. Our development team (one extremely dedicated
                developer) works tirelessly to make that a reality. We're already partnered with leading cybersecurity
                companies and constantly push updates to keep up with the latest threats. We hope you enjoy using
                Osprey, and we welcome your feedback and contributions to make it even better.
            </p>
        </div>
    </section>

    <section class="band">
        <h2 class="band-title">How Osprey compares</h2>
        <div class="table-scroll" tabindex="0" role="region" aria-label="How Osprey compares">
            <table class="compare">
                <caption class="sr-only">How Osprey compares to your browser's built-in protection, Malwarebytes, and
                    Bitdefender
                </caption>
                <thead>
                <tr>
                    <th scope="col"><span class="sr-only">Feature</span></th>
                    <th scope="col" class="col-osprey">Osprey</th>
                    <th scope="col">Your browser alone</th>
                    <th scope="col">Malwarebytes</th>
                    <th scope="col">Bitdefender</th>
                </tr>
                </thead>
                <tbody>
                {
                    comparison.map((row) => (
                            <tr>
                                <th scope="row">{row.feature}</th>
                                <td class="col-osprey">
                                    {row.osprey === 'yes' ? <span class="yes">Yes</span> :
                                            <span class="val">{row.osprey}</span>}
                                </td>
                                <td>
                                    {row.builtin === 'yes' ? <span class="yes">Yes</span> : row.builtin === 'no' ?
                                            <span class="no">No</span> : <span class="val">{row.builtin}</span>}
                                </td>
                                <td>
                                    {row.malwarebytes === 'yes' ?
                                            <span class="yes">Yes</span> : row.malwarebytes === 'no' ?
                                                    <span class="no">No</span> :
                                                    <span class="val">{row.malwarebytes}</span>}
                                </td>
                                <td>
                                    {row.bitdefender === 'yes' ?
                                            <span class="yes">Yes</span> : row.bitdefender === 'no' ?
                                                    <span class="no">No</span> :
                                                    <span class="val">{row.bitdefender}</span>}
                                </td>
                            </tr>
                    ))
                }
                </tbody>
            </table>
        </div>
    </section>

    <section class="band">
        <h2 class="band-title">Common questions</h2>
        {
            faqs.map((faq) => (
                    <details class="faq">
                        <summary>{faq.q}</summary>
                        <p>{faq.a}</p>
                    </details>
            ))
        }
    </section>

    <section class="band">
        <h2 class="band-title">Something not working?</h2>
        <div class="prose">
            <p class="band-sub">
                Email <a href="mailto:support@osprey.ac">support@osprey.ac</a> or create an issue
                on <a href="https://github.com/OspreyProject/Osprey/issues/new/choose"
                      aria-label="Create an issue on GitHub">GitHub</a>.
                <br>
                We'll get back to you as soon as we can.
            </p>
        </div>
    </section>

    <dialog id="lightbox" class="lightbox" aria-label="Screenshot">
        <img id="lightbox-img" src="" alt=""/>
    </dialog>
</Base>

<script>
    (() => {
        const track = document.querySelector<HTMLElement>('[data-marquee]');

        // If the track doesn't exist, don't try to run the marquee animation
        if (!track) {
            return;
        }

        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // If the user prefers reduced motion, don't want to run the marquee animation at all
        if (prefersReduced) {
            return;
        }

        const speed = 25; // pixels per second

        const original = Array.from(track.querySelectorAll('[data-marquee-set]'))
            .map((el) => el.cloneNode(true) as HTMLElement);

        const setWidthOf = (nodes: HTMLElement[]) =>
            nodes.reduce((sum, el) => sum + el.getBoundingClientRect().width, 0);

        const setup = () => {
            // Remove any existing clones before recalculating
            track.querySelectorAll('[data-marquee-clone]').forEach((n) => n.remove());

            const setWidth = setWidthOf(
                Array.from(
                    track.querySelectorAll('[data-marquee-set]:not([data-marquee-clone])'),
                ) as HTMLElement[],
            );

            // If the set width is 0, we can't calculate a duration, so just return early
            if (setWidth === 0) {
                return;
            }

            const target = window.innerWidth + setWidth * 2;
            let guard = 0;

            // Keep cloning the set until the track is wide enough to fill the screen and allow for a smooth scroll
            while (track.scrollWidth < target && guard < 50) {
                for (const el of original) {
                    const clone = el.cloneNode(true) as HTMLElement;
                    clone.setAttribute('data-marquee-clone', '');
                    clone.setAttribute('aria-hidden', 'true');
                    track.appendChild(clone);
                }

                guard += 1;
            }

            track.style.setProperty('--set-width', `${setWidth}px`);
            track.style.setProperty('--marquee-duration', `${setWidth / speed}s`);
        };

        let rerunTimer: number | undefined;

        const scheduleSetup = () => {
            window.clearTimeout(rerunTimer);
            rerunTimer = window.setTimeout(setup, 200);
        };

        // Run setup once immediately
        setup();

        // Schedule setup to run again when images load
        track.querySelectorAll('img').forEach((img) => {
            if (img.complete) {
                return;
            }

            img.addEventListener('load', scheduleSetup, {once: true});
            img.addEventListener('error', scheduleSetup, {once: true});
        });

        // Schedule setup to run again when the window loads
        window.addEventListener('load', scheduleSetup);

        // Schedule setup to run again when the track's size changes
        new ResizeObserver(scheduleSetup).observe(track.parentElement ?? track);

        // Schedule setup to run again when the theme changes
        new MutationObserver(scheduleSetup).observe(document.documentElement, {
            attributes: true,
            attributeFilter: ['data-theme'],
        });
    })();

    const dialog = document.getElementById('lightbox') as HTMLDialogElement | null;
    const dialogImg = document.getElementById('lightbox-img') as HTMLImageElement | null;

    if (dialog && dialogImg) {
        // Add click event listeners to all shot triggers to open the lightbox dialog
        document.querySelectorAll<HTMLButtonElement>('.shot-trigger').forEach((trigger) => {
            trigger.addEventListener('click', () => {
                const full = trigger.dataset.full;

                // If the full image URL is not set, don't try to open the dialog
                if (!full) {
                    return;
                }

                // Set the dialog image's src and alt attributes, then show the dialog
                dialogImg.src = full;
                dialogImg.alt = trigger.querySelector('img')?.alt ?? '';
                dialog.showModal();
            });
        });

        // Add a click event listener to the dialog to close it when clicking outside the image
        dialog.addEventListener('click', (event) => {
            if (event.target !== dialogImg) {
                dialog.close();
            }
        });

        // Add a keydown event listener to the dialog to close it when pressing the Escape key
        dialog.addEventListener('close', () => {
            dialogImg.src = '';
        });
    }
</script>
