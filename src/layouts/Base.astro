---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
    title: string;
    description: string;
    schema?: object;
}

const {title, description, schema} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og-image.png', Astro.site);
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>{title}</title>
    <meta name="description" content={description}/>
    <link rel="canonical" href={canonical}/>
    <link rel="icon" href="/favicon.png" type="image/png"/>
    <link rel="apple-touch-icon" href="/apple-touch-icon.png"/>

    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1"/>

    <meta property="og:site_name" content="Osprey"/>
    <meta property="og:title" content={title}/>
    <meta property="og:description" content={description}/>
    <meta property="og:url" content={canonical}/>
    <meta property="og:type" content="website"/>
    <meta property="og:image" content={ogImage}/>
    <meta property="og:image:width" content="1200"/>
    <meta property="og:image:height" content="630"/>
    <meta property="og:image:alt"
          content="Osprey: Browser Protection. Automatically blocks phishing, malware, scams, and dangerous websites while you browse. Free protection for safer browsing."/>
    <meta property="og:locale" content="en_US"/>

    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:site" content="@OspreyExtension"/>
    <meta name="twitter:title" content={title}/>
    <meta name="twitter:description" content={description}/>
    <meta name="twitter:image" content={ogImage}/>

    {schema && <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)}/>}

    <!-- Google tag (gtag.js), loaded lazily to keep it off the critical path -->
    <script is:inline>
        window.dataLayer = window.dataLayer || [];

        function gtag() {
            dataLayer.push(arguments);
        }

        gtag('js', new Date());
        gtag('config', 'G-SF2K7JR45G');

        let gtagLoaded = false;

        function loadGtag() {
            if (gtagLoaded) {
                return;
            }

            gtagLoaded = true;

            const script = document.createElement('script');
            script.async = true;
            script.src = 'https://www.googletagmanager.com/gtag/js?id=G-SF2K7JR45G';
            document.head.appendChild(script);
        }

        const triggers = ['scroll', 'pointerdown', 'keydown', 'touchstart'];
        triggers.forEach((event) =>
            window.addEventListener(event, loadGtag, {once: true, passive: true})
        );

        if ('requestIdleCallback' in window) {
            requestIdleCallback(loadGtag, {timeout: 6000});
        } else {
            setTimeout(loadGtag, 4000);
        }
    </script>

    <script is:inline>
        (function () {
            const ua = navigator.userAgent;
            let id = 'chrome';

            if (/firefox|fxios/i.test(ua)) {
                id = 'firefox';
            } else if (/edg\//i.test(ua)) {
                id = 'edge';
            }

            document.documentElement.setAttribute('data-browser', id);
        })();
    </script>
</head>
<body>
<Header/>
<main>
    <div class="wrap">
        <slot/>
    </div>
</main>
<Footer/>
</body>
</html>
